{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": true,
    "noEmit": false,
    "outDir": "./.tmp-tests",

    "skipLibCheck": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "types": ["vitest/globals"]
  },

  "include": [
    "tests/**/*.ts"
  ],

  "exclude": [
    "src"
  ]
}
