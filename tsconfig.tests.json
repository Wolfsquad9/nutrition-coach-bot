{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,
    "noEmit": false,
    "outDir": "./.tmp-tests",

    "skipLibCheck": true,
    "resolveJsonModule": true,

    "types": ["vitest/globals"]
  },

  "include": [
    "tests/**/*.ts"
  ]
}
