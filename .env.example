# Supabase Configuration
# Get these values from your Supabase project: https://app.supabase.com/project/_/settings/api
#
# IMPORTANT: Never commit the real .env file. This file is a template.
# Copy to .env and fill in your actual values.

# Public URL of your Supabase project (no trailing slash)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase anonymous (public) key — safe to expose in client code
# JWT string starting with "eyJ..."
VITE_SUPABASE_ANON_KEY=<your-anon-public-key>

# Alphanumeric reference ID of your Supabase project
VITE_SUPABASE_PROJECT_ID=<project-ref>

# Server-side only keys (NEVER prefix with VITE_, never expose to client)
# Used only by Supabase Edge Functions, not by the frontend
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=<your-anon-public-key>

# Optional: Sentry DSN for error reporting.
# Get from https://sentry.io → Project Settings → Client Keys → DSN.
# If unset, Sentry stays inactive and the app runs unchanged.
VITE_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
